---
# ansible-lint configuration for ansible_aws_vpc
# Docs: https://ansible-lint.readthedocs.io/configuring/

# Use the 'basic' profile — enables syntax, deprecation, and best-practice checks
# without requiring every enterprise convention (roles, FQCN, strict naming, etc.)
profile: basic

# ── Rules to skip entirely ────────────────────────────────────────────────────
skip_list:
  # Playbooks use short module names (e.g. ec2_vpc_net, ec2_group).
  # Enforcing FQCN here would require touching every task; left as a future
  # migration item tracked in SETUP.md.
  - fqcn[action-core]
  - fqcn[action]

  # Variable names follow a project convention (PubSub1Cidr, NATGW_out, MYIP)
  # that pre-dates ansible-lint's naming rules.  Renaming them would break the
  # output_vars bridge between the two playbooks.
  - var-naming[no-role-prefix]

  # The copy task that writes vars/output_vars has an intentionally long
  # content: line.  Wrapping it would reduce readability.
  - yaml[line-length]

  # AWS modules self-report changed/unchanged via their own return values;
  # adding explicit changed_when to every ec2_* task would be misleading.
  - no-changed-when

# ── Rules to warn on (fail-only in CI if you promote them to skip_list) ──────
warn_list:
  # Task names mix sentence-case and imperative-case; warn but don't fail.
  - name[casing]

  # include_vars is acceptable here (no dynamic paths); prefer import_vars
  # in future refactors.
  - include-vars-without-filter

# ── Paths to exclude from linting ────────────────────────────────────────────
exclude_paths:
  # Auto-generated by vpc_setup.yml — not a playbook or task file.
  - vars/output_vars

# ── Miscellaneous options ─────────────────────────────────────────────────────
# Show rule IDs next to every warning so they can be added to skip_list easily.
verbosity: 1

# Treat warnings as non-fatal (exit 0) so CI pipelines can choose their own
# threshold.  Set to true to make warnings block the pipeline.
strict: false
