# Ansible / Python artefacts
*.retry
ansible.log
*.log

# Auto-generated bridge file written by vpc_setup.yml.
# This file is environment-specific (contains live AWS resource IDs) and
# should not be committed.  Each developer generates their own copy by
# running vpc_setup.yml.
vars/output_vars

# EC2 key pair private key — NEVER commit private keys.
bastion-key.pem
*.pem

# Ansible fact cache (enabled via ansible.cfg if gather_facts is turned on)
.ansible_cache/
fact_cache/

# Ansible collection installs (restored via: ansible-galaxy collection install -r requirements.yml)
collections/

# Ansible role installs (restored via: ansible-galaxy role install -r requirements.yml)
roles/

# Python virtual environments
venv/
.venv/
env/
.env/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Editor / OS artefacts
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
